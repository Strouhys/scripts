# Zkopirujte tento soubor jako .env a upravte cesty podle serveru.
SOURCE_DIR=C:\Reporting NT\dp\done
TARGET_DIR=C:\Reporting NT\dp_archiv\dp_log

# Maska souboru. Pro vsechny .log soubory nechte *.log
FILE_PATTERN=*.log

# Presouvaji se pouze soubory starsi nez tento pocet hodin.
MIN_AGE_HOURS=24

# true = jen vypise, co by udelal; false = opravdu presouva
DRY_RUN=false

# Relativni cesta se pocita od slozky, kde lezi tento skript.
JOB_LOG_FILE=logs\move_old_logs.log
